# ── IDE / OS ─────────────────────────────────────────────────────────────
.metadata/
.idea/
.vscode/
*.iml
.DS_Store
Thumbs.db
desktop.ini

# ── Node / React / Electron (frontend) ───────────────────────────────────
**/node_modules/
**/dist/
**/dist-ssr/
**/.env.local
**/.env.*.local

# Electron Builder output (upload via GitHub Releases, not git)
**/release/
!**/release/.gitkeep

# Bundled build artifacts (regenerated by npm run dist / build:backend)
**/resources/backend/crm-backend.jar
**/resources/jre/
**/resources/jre-download.zip
**/resources/jre-extract/

# Generated app icons (source: build/icon.svg — run npm run icons)
**/build/icon.png
**/build/icon.ico

# Logs
**/*.log
**/logs/

# SQLite / local databases (created at runtime in user AppData)
**/*.db
**/*.db-journal
**/*.db-wal
**/*.db-shm

# Java / Maven
**/target/
**/.classpath
**/.project
**/.settings/
**/.apt_generated
**/.factorypath
**/.springBeans
**/.sts4-cache

# Temp / cache
**/.cache/
**/tmp/
**/*.tmp
**/*.temp

# Secrets (never commit)
**/.env
!CRM_FRONTEND/.env.electron
