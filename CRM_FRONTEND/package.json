{
  "name": "crm-desktop",
  "private": true,
  "version": "1.0.0",
  "description": "CRM Desktop — professional customer relationship management",
  "author": "Adithya",
  "type": "module",
  "main": "electron/main.cjs",
  "scripts": {
    "dev": "vite",
    "build": "vite build",
    "lint": "eslint .",
    "preview": "vite preview",
    "icons": "node scripts/generate-icons.mjs",
    "build:backend": "node scripts/build-backend.mjs",
    "download:jre": "node scripts/download-jre.mjs",
    "download:jre:mac-cache": "node scripts/download-mac-jre-cache.mjs",
    "electron": "concurrently -k \"cross-env VITE_ELECTRON=true vite --mode electron --port 5173\" \"wait-on http://127.0.0.1:5173 && cross-env NODE_ENV=development electron .\"",
    "preelectron": "node scripts/ensure-backend-jar.mjs && node scripts/ensure-jre.mjs",
    "predist": "npm run build:backend && npm run download:jre && npm run icons",
    "predist:mac": "npm run build:backend && npm run download:jre:mac-cache && npm run icons",
    "dist": "cross-env VITE_ELECTRON=true vite build --mode electron && electron-builder --win",
    "dist:dir": "cross-env VITE_ELECTRON=true vite build --mode electron && electron-builder --win --dir",
    "dist:mac": "cross-env VITE_ELECTRON=true vite build --mode electron && electron-builder --mac --x64 --arm64",
    "dist:mac:dir": "cross-env VITE_ELECTRON=true vite build --mode electron && electron-builder --mac --dir"
  },
  "dependencies": {
    "axios": "^1.15.2",
    "lucide-react": "^1.14.0",
    "react": "^19.1.0",
    "react-dom": "^19.1.0",
    "react-router-dom": "^7.14.2",
    "recharts": "^2.15.4",
    "xlsx": "^0.18.5"
  },
  "devDependencies": {
    "@eslint/js": "^9.30.1",
    "@types/react": "^19.1.8",
    "@types/react-dom": "^19.1.6",
    "@vitejs/plugin-react": "^4.6.0",
    "concurrently": "^9.1.2",
    "cross-env": "^7.0.3",
    "electron": "^35.0.0",
    "electron-builder": "^25.1.8",
    "eslint": "^9.30.1",
    "eslint-plugin-react-hooks": "^5.2.0",
    "eslint-plugin-react-refresh": "^0.4.20",
    "globals": "^16.3.0",
    "png2icons": "^2.0.1",
    "sharp": "^0.34.2",
    "tar": "^7.5.15",
    "to-ico": "^1.1.5",
    "vite": "^7.0.4",
    "wait-on": "^8.0.3"
  },
  "build": {
    "appId": "com.adithya.crm.desktop",
    "productName": "CRM Desktop",
    "copyright": "Copyright © 2026 Adithya",
    "asar": true,
    "beforePack": "./scripts/before-pack.cjs",
    "directories": {
      "output": "release",
      "buildResources": "build"
    },
    "files": [
      "dist/**/*",
      "electron/**/*",
      "build/icon.png",
      "package.json"
    ],
    "extraResources": [
      {
        "from": "resources/backend",
        "to": "backend",
        "filter": [
          "**/*",
          "*.jar"
        ]
      },
      {
        "from": "resources/jre",
        "to": "jre",
        "filter": [
          "**/*"
        ]
      }
    ],
    "win": {
      "target": [
        {
          "target": "nsis",
          "arch": [
            "x64"
          ]
        }
      ],
      "icon": "build/icon.ico",
      "requestedExecutionLevel": "asInvoker",
      "signAndEditExecutable": false
    },
    "nsis": {
      "oneClick": false,
      "perMachine": false,
      "allowToChangeInstallationDirectory": true,
      "allowElevation": true,
      "installerIcon": "build/icon.ico",
      "uninstallerIcon": "build/icon.ico",
      "installerHeaderIcon": "build/icon.ico",
      "createDesktopShortcut": true,
      "createStartMenuShortcut": true,
      "shortcutName": "CRM Desktop",
      "artifactName": "CRM-Desktop-Setup-${version}.${ext}"
    },
    "mac": {
      "category": "public.app-category.business",
      "icon": "build/icon.icns",
      "darkModeSupport": true,
      "hardenedRuntime": true,
      "gatekeeperAssess": false,
      "type": "distribution",
      "entitlements": "build/entitlements.mac.plist",
      "entitlementsInherit": "build/entitlements.mac.inherit.plist",
      "artifactName": "CRM-Desktop-${version}-${arch}.${ext}",
      "target": [
        "dmg",
        "dir"
      ]
    },
    "dmg": {
      "title": "${productName} ${version}",
      "contents": [
        {
          "x": 130,
          "y": 220
        },
        {
          "x": 410,
          "y": 220,
          "type": "link",
          "path": "/Applications"
        }
      ],
      "window": {
        "width": 540,
        "height": 380
      }
    }
  }
}
